# ════════════════════════════════════════════════════════════════════════════════
#  W3Deploy — root .gitignore
#  Covers all sub-packages: api-server, build-server, frontend, cf-worker
# ════════════════════════════════════════════════════════════════════════════════

# ── Environment & Secrets (NEVER commit these) ────────────────────────────────
.env
.env.*
!**/.env.example        # allow example/template files anywhere

# Cloudflare Workers local secrets
.dev.vars
.dev.vars.*
!**/.dev.vars.example

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
jspm_packages/

# ── Build & Output ────────────────────────────────────────────────────────────
dist/
dist-ssr/
out/
build/
output/
.next/
.nuxt/

# ── Cloudflare / Wrangler ─────────────────────────────────────────────────────
.wrangler/              # local Wrangler build cache & state

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Test & Coverage ───────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Caches ────────────────────────────────────────────────────────────────────
.cache/
.parcel-cache/
.vite/
.eslintcache
.stylelintcache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# ── Package manager misc ──────────────────────────────────────────────────────
.npm
.yarn-integrity
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*
*.tgz
package-lock.json       # uncomment if you prefer to ignore lock files

# ── Runtime / OS ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pid
*.pid.lock
*.seed
pids/

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.vscode-test/

# ── Diagnostic reports ────────────────────────────────────────────────────────
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json
