# ── Cloudflare / Wrangler ─────────────────────────────────────────────────────
.wrangler/          # local Wrangler state & build cache
.dev.vars           # local secret overrides (equivalent of .env for Workers)
.dev.vars.*
!.dev.vars.example  # keep the example template

# ── Environment / Secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example       # keep the example template

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Build / Output ────────────────────────────────────────────────────────────
dist/
out/

# ── Test coverage ─────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
